// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "darwin", "darwin-arm64", "windows", "linux-musl"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ClipboardItem {
  id                   String   @id @default(cuid())
  content_hash         String   @unique // For deduplication
  content_type         String   // 'text', 'image', 'file', 'link', 'color'
  content              String   // Text representation or file path
  raw_content          Bytes?   // Binary data for images/files
  metadata             String?  // JSON string for additional data
  source_app           String?  // App that created this clipboard item
  is_sensitive         Boolean  @default(false) // Whether content contains sensitive data
  sensitive_types      String?  // JSON array of detected sensitive data types
  sensitive_confidence String?  // Confidence level: 'low', 'medium', 'high'
  created_at           DateTime @default(now())
  accessed_at          DateTime @default(now())
  access_count         Int      @default(1)
  is_favorite          Boolean  @default(false)
  is_deleted           Boolean  @default(false)

  // Relations
  tags ItemTag[]

  @@map("clipboard_items")
}

model Tag {
  id         String   @id @default(cuid())
  name       String   @unique
  color      String?  // Hex color for tag
  created_at DateTime @default(now())

  // Relations
  items ItemTag[]

  @@map("tags")
}

model ItemTag {
  item_id String
  tag_id  String

  // Relations
  item ClipboardItem @relation(fields: [item_id], references: [id], onDelete: Cascade)
  tag  Tag           @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([item_id, tag_id])
  @@map("item_tags")
}

model Snippet {
  id         String   @id @default(cuid())
  name       String
  content    String
  shortcut   String?  @unique // Keyboard shortcut for quick access
  variables  String?  // JSON string for template variables
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("snippets")
}

model Setting {
  key        String   @id
  value      String   // JSON string for complex values
  updated_at DateTime @default(now()) @updatedAt

  @@map("settings")
}

model License {
  id            String    @id @default(cuid())
  license_key   String    @unique
  purchase_date DateTime
  expires_at    DateTime?
  is_valid      Boolean   @default(true)
  created_at    DateTime  @default(now())

  @@map("license")
}
